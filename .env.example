# oopsys (only OOPSYS_* is read by the library)
OOPSYS_IS_DEVELOPMENT=true
OOPSYS_SERVICE_NAME=my-app
OOPSYS_LOGGER_NAME=OOPSYS
OOPSYS_RERAISE=false
OOPSYS_AGENT__ENABLED=false
OOPSYS_AGENT__HOST=localhost
OOPSYS_AGENT__PORT=8080
OOPSYS_AGENT__PATH=/reports

# your application (examples — not read by oopsys)
# DEV=true
# DATABASE_URL=...
